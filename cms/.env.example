# Banco do Payload (Postgres) — ver docker-compose.dev.yml na raiz
DATABASE_URI=postgres://payload:payload@localhost:5433/portal_legislativo
# Segredo do Payload (gere um forte: openssl rand -hex 32)
PAYLOAD_SECRET=CHANGE_ME
# URL pública do portal (sem barra final) — usada em metadataBase, sitemap e robots
NEXT_PUBLIC_SITE_URL=https://camaramunicipal.seu-dominio.com.br

# SAPL — fonte do processo legislativo
SAPL_API_BASE=http://localhost:8010
# SAPL_API_TOKEN=   # opcional — só se a câmara exigir autenticação para leitura

# GlitchTip — DSN do projeto (Settings > Client Keys no painel GlitchTip)
NEXT_PUBLIC_SENTRY_DSN=https://<key>@glitchtip.seu-dominio.com/<project-id>

# Umami Analytics (Settings > Websites no painel Umami)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_UMAMI_SRC=https://analytics.seu-dominio.com/script.js
