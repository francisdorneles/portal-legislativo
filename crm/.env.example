# Banco do CRM (docker compose -f docker-compose.dev.yml up -d)
DATABASE_URL="postgresql://crm:crm@localhost:5434/crm_legislativo"
REDIS_URL="redis://localhost:6380"
# Gere um segredo: openssl rand -base64 32  (ou npx auth secret)
AUTH_SECRET="troque-isto"
AUTH_TRUST_HOST="true"

# ---------- IA (Fase 3 — híbrido) ----------
# Provedor de embeddings: stub (offline/teste) | ollama (local) | openai (fronteira)
IA_EMBED_PROVIDER=stub
# Geração por tier (tarefas baratas no local, difíceis na fronteira): stub|ollama|openai
IA_GEN_LOCAL=stub
IA_GEN_FRONTIER=stub
# Ollama local (privacidade total) — precisa do Ollama rodando
IA_OLLAMA_URL=http://localhost:11434
IA_OLLAMA_EMBED_MODEL=bge-m3
IA_OLLAMA_GEN_MODEL=qwen2.5:14b
# Fronteira (OpenAI-compatible) — ex.: Groq (llama-3.3-70b). Cole sua IA_FRONTIER_KEY.
IA_FRONTIER_URL=https://api.groq.com/openai/v1
IA_FRONTIER_KEY=
IA_FRONTIER_MODEL=llama-3.3-70b-versatile
# OpenAI (embeddings + geração) — RECOMENDADO na hospedagem do usuário
IA_OPENAI_URL=https://api.openai.com/v1
IA_OPENAI_KEY=
IA_OPENAI_EMBED_MODEL=text-embedding-3-small
# Captura multimodal: voz (Whisper, via OpenAI) e foto (visão, via modelo de fronteira).
IA_OPENAI_TRANSCRIBE_MODEL=whisper-1
# IA_VISION_MODEL=        # vazio = usa IA_FRONTIER_MODEL (gpt-4o-mini tem visão)
# Config recomendada p/ produção (OpenAI primário):
#   IA_EMBED_PROVIDER=openai
#   IA_GEN_LOCAL=openai      (chat/extração)   IA_FRONTIER_MODEL=gpt-4o
#   IA_GEN_FRONTIER=openai   (proposição/raciocínio)
#   IA_FRONTIER_URL=https://api.openai.com/v1  IA_FRONTIER_KEY=<sua key>  IA_FRONTIER_MODEL=gpt-4o
# Modo 100% privado (sem dado saindo): IA_EMBED_PROVIDER=ollama / IA_GEN_*=ollama

# Querido Diário (diário oficial) — público (Cloudflare pode bloquear servidor) ou self-hosted
QD_API_URL=https://api.queridodiario.ok.org.br

# SAPL (proposições/parlamentares) — NÃO é env: a URL mora em Camara.saplUrl (por câmara).
# Cada câmara que usa Interlegis expõe {saplUrl}/api/ público. Câmaras sem SAPL → conector degrada.

# WhatsApp via Zernio (BSP oficial sobre a Meta Cloud API). Sem isto, canal WHATSAPP degrada
# (ok:false) e canal REGISTRO segue no-op. Confirmar ZERNIO_SEND_PATH na API reference do painel.
ZERNIO_API_URL=https://zernio.com/api/v1
ZERNIO_API_KEY=
ZERNIO_ACCOUNT_ID=
ZERNIO_SEND_PATH=/messages
ZERNIO_TEMPLATE_LANG=pt_BR
# Templates aprovados na Meta p/ notificação proativa (fora das 24h), por tipo de comunicação:
# ZERNIO_TEMPLATE_DEMANDA_RESOLVIDA=demanda_resolvida
# ZERNIO_TEMPLATE_ANIVERSARIO=aniversario
